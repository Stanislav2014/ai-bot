# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# LLM server base URL (Lemonade, Ollama, vLLM, etc.).
# Lemonade — отдельный проект (../lemonade-server), соединение через общую docker-сеть `llm-net`.
# Для локального запуска без Docker используй http://localhost:8000/api.
LLM_BASE_URL=http://lemonade:8000/api

# Default LLM model
DEFAULT_MODEL=Qwen3-0.6B-GGUF

# LLM request timeout in seconds
LLM_TIMEOUT=120

# Logging level
LOG_LEVEL=INFO

# Dialog history directory (per-user YAML files)
HISTORY_DIR=data/history

# Per-user state directory (current model selection, YAML per-user)
USERS_DIR=data/users

# Enable dialog history (false = stateless, every message independent, /reset a no-op)
HISTORY_ENABLED=true

# Max messages kept per user (0 = unlimited)
HISTORY_MAX_MESSAGES=20

# Max total chars in dialog history (0 = unlimited)
HISTORY_MAX_CHARS=8000

# Summarize history when len > threshold (0 = disabled)
HISTORY_SUMMARIZE_THRESHOLD=5

# Raw messages kept after summarization
HISTORY_KEEP_RECENT=2

# Model for summarization LLM call (empty = use DEFAULT_MODEL)
HISTORY_SUMMARIZE_MODEL=

# System prompt — defines the bot persona (prepended to every LLM request)
SYSTEM_PROMPT=Ты опытный программист и отвечаешь кратко и по делу.

# Feature flag: enable/disable LLM. When false, ChatService.reply returns LLM_DISABLED_REPLY
# without calling the model (useful for maintenance windows / cost control).
LLM_ENABLED=true
LLM_DISABLED_REPLY=🛠 AI временно отключён (maintenance). Сообщение получено, но не обработано.

# Log full LLM context (messages with content) before each request — disable in production if logs grow
LOG_CONTEXT_FULL=true

# Duplicate structured logs to a rotating file inside the project (empty = stdout only).
# File stays inside the bind-mounted ./data volume so logs survive container recreate.
# Rotation: 10MB per file, 5 historical backups (total ~50MB max).
LOG_FILE=data/logs/bot.log

# Container UID/GID — must match the owner of ./data on host for the bind-mount to be writable.
# Defaults (1000:1000) work on most Linux dev machines. If your host user has a different UID,
# set it here (find with: id -u and id -g) to avoid PermissionError on HistoryStore mkdir.
# UID=1000
# GID=1000
